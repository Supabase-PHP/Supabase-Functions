{
    "name": "supabase-php/supabase-functions",
    "description": "Supabase Edge functions for php",
    "keywords": [
      "supabase",
      "functions",
      "supabase-php",
      "supabase-functions"
    ],
    "homepage": "https://github.com/supabase-php/supabase-functions",
    "type": "library",
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "tomasvotruba/type-coverage": "^2.1",
        "laravel/pint": "^1.29",
        "phpunit/phpunit": "^13.1",
        "phpstan/extension-installer": "^1.4"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Supabase\\Functions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Supabase\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Sushil Kumar",
            "email": "sushilkumbhar77@gmail.com"
        }
    ],
    "scripts": {
        "test:lint": "pint",
        "test:unit": "phpunit",
        "test:coverage": "phpunit --coverage-text --coverage-clover coverage.xml",
        "test:type": "phpstan analyse",
        "test": [
            "@test:lint",
            "@test:type",
            "@test:unit"
        ]
    },
    "config": {
      "preferred-install": "dist",
      "optimize-autoloader": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
